---
import Layout from '@/layouts/Layout.astro';
import portadaImg from '@/img/soporte/portada.webp';
---

<Layout
  title="Soporte | Proyectos CSI"
  description="Soporte técnico profesional para tus soluciones. Contáctanos vía email, teléfono o crea un ticket de soporte. Nuestro equipo responde en menos de 24 horas."
>
  <!-- Hero -->
  <section class="relative h-80 md:h-96 flex items-center justify-center overflow-hidden" style={`background-image: url(${portadaImg.src}); background-size: cover; background-position: center;`}>
    <div class="absolute inset-0 bg-black/75"></div>
    <div class="relative text-center text-white px-4 max-w-3xl z-10">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 drop-shadow-lg">Soporte</h1>
      <p class="text-lg md:text-xl text-gray-100 drop-shadow">Estamos aquí para resolver tus problemas técnicos</p>
    </div>
  </section>

  <!-- Introducción -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">En Proyectos CSI estamos aquí para ayudarte.</h2>
        <p class="text-lg text-gray-600 leading-relaxed">
          Si tienes problemas técnicos o dudas, nuestro equipo de soporte está disponible para brindarte asistencia rápida y profesional. Estamos comprometidos con tu satisfacción.
        </p>
      </div>
    </div>
  </section>

  <!-- Sección de Contacto de Soporte -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
        <!-- Lado Izquierdo: Información -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Contáctanos</h2>
          <p class="text-lg text-gray-600 mb-8">
            Si necesitas ayuda, estamos disponibles para responder tus dudas.
          </p>

          <!-- Botones de Contacto -->
          <div class="space-y-4 mb-10">
            <a 
              href="mailto:info@proyectoscsi.mx,samuel@proyectoscsi.mx"
              class="flex items-center justify-center w-full bg-gray-900 text-white py-3 px-6 rounded-full font-semibold hover:bg-gray-800 transition-colors"
            >
              Enviar Email
            </a>
            <a 
              href="tel:+523341708104"
              class="flex items-center justify-center w-full bg-gray-900 text-white py-3 px-6 rounded-full font-semibold hover:bg-gray-800 transition-colors"
            >
              +52 33 4170 8104
            </a>
            <button 
              onclick="openSupportTicket()"
              class="flex items-center justify-center w-full bg-gray-900 text-white py-3 px-6 rounded-full font-semibold hover:bg-gray-800 transition-colors"
            >
              Crear Ticket de Soporte
            </button>
          </div>

          <!-- Información Adicional -->
          <div class="space-y-4 text-sm">
            <div>
              <p class="text-gray-600">
                <strong class="text-gray-900">Chat:</strong> <span class="text-gray-500">(Disponible en la esquina inferior derecha)</span>
              </p>
            </div>
            <div>
              <p class="text-gray-900 font-semibold mb-1">Tiempo de respuesta:</p>
              <p class="text-gray-600">Nuestro equipo atenderá tu solicitud lo antes posible.</p>
            </div>
          </div>
        </div>

        <!-- Lado Derecho: Imagen -->
        <div class="flex justify-center">
          <div class="relative">
            <img 
              src="/img/soporte/Soporte.webp" 
              alt="Soporte técnico" 
              class="w-full max-w-md h-auto"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Canales de Soporte -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Canales de Soporte</h2>
        <p class="text-lg text-gray-600">
          Tenemos múltiples canales disponibles para que puedas contactarnos de la forma que prefieras.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Email -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center hover:shadow-lg transition-shadow">
          <div class="flex justify-center mb-4">
            <svg class="w-12 h-12 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Email</h3>
          <p class="text-gray-600 mb-4">Envía tus consultas y documentación.</p>
          <div class="space-y-2">
            <a href="mailto:info@proyectoscsi.mx" class="text-gray-900 font-semibold hover:underline block">
              info@proyectoscsi.mx
            </a>
            <a href="mailto:samuel@proyectoscsi.mx" class="text-gray-900 font-semibold hover:underline block">
              samuel@proyectoscsi.mx
            </a>
          </div>
        </div>

        <!-- Teléfono -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center hover:shadow-lg transition-shadow">
          <div class="flex justify-center mb-4">
            <svg class="w-12 h-12 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Teléfono</h3>
          <p class="text-gray-600 mb-4">Habla directamente con nuestro equipo.</p>
          <a href="tel:+523341708104" class="text-gray-900 font-semibold hover:underline">
            +52 33 4170 8104
          </a>
        </div>

        <!-- Ticket de Soporte -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center hover:shadow-lg transition-shadow">
          <div class="flex justify-center mb-4">
            <svg class="w-12 h-12 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Ticket de Soporte</h3>
          <p class="text-gray-600 mb-4">Crea un ticket para seguimiento detallado.</p>
          <button 
            onclick="openSupportTicket()"
            class="text-gray-900 font-semibold hover:underline"
          >
            Crear Ticket
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Información de Soporte -->
  <section class="section-padding bg-gray-900 text-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <h3 class="text-2xl font-bold mb-2">24/7</h3>
          <p class="text-gray-300">Disponibilidad de soporte continuó para emergencias</p>
        </div>
        <div class="text-center">
          <h3 class="text-2xl font-bold mb-2">&lt;24 horas</h3>
          <p class="text-gray-300">Tiempo promedio de respuesta a solicitudes</p>
        </div>
        <div class="text-center">
          <h3 class="text-2xl font-bold mb-2">Equipo Experto</h3>
          <p class="text-gray-300">Técnicos especializados en todas las áreas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          ¿Necesitas Ayuda Ahora?
        </h2>
        <p class="text-xl text-gray-600 mb-10">
          No dudes en contactarnos. Estamos aquí para asegurarnos de que tu solución funcione perfectamente.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+523341708104" class="inline-block bg-gray-900 text-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-800 transition-colors">
            Llamar Ahora
          </a>
          <a href="mailto:info@proyectoscsi.mx,samuel@proyectoscsi.mx" class="inline-block border-2 border-gray-900 text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-900 hover:text-white transition-colors">
            Enviar Email
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Síguenos en Redes Sociales -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8">
          Síguenos en Redes Sociales
        </h2>
        <div class="flex justify-center gap-4 flex-wrap">
          <!-- Facebook -->
          <a 
            href="https://www.facebook.com/ProyectosCSI/" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-16 h-16 bg-black rounded-lg hover:bg-gray-800 transition-all hover:scale-110"
            aria-label="Facebook"
          >
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>

          <!-- Twitter / X -->
          <a 
            href="https://x.com/ProyectosCSI" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-16 h-16 bg-black rounded-lg hover:bg-gray-800 transition-all hover:scale-110"
            aria-label="Twitter"
          >
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 002.856-3.915 10 10 0 01-2.856.973 5 5 0 00-8.59 4.547 14.29 14.29 0 01-10.336-5.245 5 5 0 001.546 6.657 5.023 5.023 0 01-2.265-.617v.06a5 5 0 004.009 4.906 5 5 0 01-2.257.086 5.005 5.005 0 004.669 3.473 10.025 10.025 0 01-6.177 2.13c-.398 0-.779-.023-1.17-.067a14.096 14.096 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a 
            href="https://www.linkedin.com/company/99545260/" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-16 h-16 bg-black rounded-lg hover:bg-gray-800 transition-all hover:scale-110"
            aria-label="LinkedIn"
          >
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd" />
            </svg>
          </a>

          <!-- YouTube -->
          <a 
            href="https://www.youtube.com/@ProyectosCSI-x7e" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-16 h-16 bg-black rounded-lg hover:bg-gray-800 transition-all hover:scale-110"
            aria-label="YouTube"
          >
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Modal para Ticket de Soporte con HubSpot -->
  <div id="ticket-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg shadow-2xl w-full max-w-2xl mx-4 relative">
      <button onclick="closeTicketModal()" class="absolute top-4 right-4 text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
      <div class="p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Crear Ticket de Soporte</h2>
        <div class="hs-form-frame" data-region="na1" data-form-id="2b4be26f-1ef5-47d1-949a-f69c3cc7258f" data-portal-id="48200776"></div>
      </div>
    </div>
  </div>
</Layout>

<script src="https://js.hsforms.net/forms/embed/48200776.js" defer></script>
<script type="module">
  // Función para abrir el modal de ticket de soporte
  window.openSupportTicket = function() {
    const modal = document.getElementById('ticket-modal');
    modal.classList.remove('hidden');
  };

  // Función para cerrar el modal de ticket
  window.closeTicketModal = function() {
    const modal = document.getElementById('ticket-modal');
    modal.classList.add('hidden');
  };

  // Cerrar modal al hacer click en el overlay
  document.getElementById('ticket-modal').addEventListener('click', function(e) {
    if (e.target === this) {
      this.classList.add('hidden');
    }
  });

  // Chatbot Widget - Drift/Intercom Style
  // Este es un chatbot minimalista personalizado
  const initChatBot = () => {
    const chatContainer = document.createElement('div');
    chatContainer.id = 'csi-chatbot-container';
    chatContainer.innerHTML = `
      <div id="csi-chatbot-widget" class="fixed bottom-4 right-4 z-50">
        <!-- Notification Bubble -->
        <div id="csi-notification" class="absolute -top-24 right-0 bg-white rounded-lg shadow-xl p-3 mb-4 flex items-center gap-3 animate-bounce-in" style="width: 240px;">
          <img src="/images/logo-dark.webp" alt="Logo Proyectos CSI" class="h-8 w-auto flex-shrink-0" />
          <div class="flex-1">
            <p class="text-sm font-semibold text-gray-900">¿Necesitas ayuda?</p>
            <p class="text-xs text-gray-600">Hablemos sobre tu proyecto</p>
          </div>
        </div>

        <div id="csi-chat-bubble" class="w-14 h-14 bg-gray-900 text-white rounded-full shadow-lg cursor-pointer flex items-center justify-center hover:bg-gray-800 transition-all" style="display: flex;">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
          </svg>
        </div>
        <div id="csi-chat-window" class="absolute bottom-20 right-0 w-96 bg-white rounded-lg shadow-2xl hidden flex-col" style="height: 500px; display: none;">
          <div class="bg-gray-900 text-white p-4 rounded-t-lg flex items-start justify-between">
            <div>
              <h3 class="font-bold text-lg">Proyectos CSI</h3>
              <p class="text-sm text-gray-300">Usualmente respondemos en minutos</p>
            </div>
            <img src="/images/logo-light.webp" alt="Logo Proyectos CSI" class="h-10 w-auto" />
          </div>
          <div id="csi-messages" class="flex-1 overflow-y-auto p-4 bg-gray-50">
            <div class="mb-3">
              <div class="bg-gray-900 text-white rounded-lg px-4 py-2 inline-block max-w-xs">
                <p class="text-sm">¡Hola! 👋 ¿En qué podemos ayudarte?</p>
              </div>
            </div>
          </div>
          <div class="border-t p-4 flex gap-2">
            <input type="text" id="csi-message-input" placeholder="Escribe tu mensaje..." class="flex-1 border border-gray-300 rounded px-3 py-2 text-sm" />
            <button id="csi-send-btn" class="bg-gray-900 text-white px-4 rounded hover:bg-gray-800">Enviar</button>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(chatContainer);

    const bubble = document.getElementById('csi-chat-bubble');
    const chatWindow = document.getElementById('csi-chat-window');
    const notification = document.getElementById('csi-notification');
    const sendBtn = document.getElementById('csi-send-btn');
    const messageInput = document.getElementById('csi-message-input');
    const messagesDiv = document.getElementById('csi-messages');

    // Ocultar notificación cuando hace clic en el bubble
    bubble.addEventListener('click', () => {
      notification.style.display = 'none';
      if (chatWindow.style.display === 'none' || !chatWindow.style.display) {
        chatWindow.style.display = 'flex';
        messageInput.focus();
      } else {
        chatWindow.style.display = 'none';
      }
    });

    sendBtn.addEventListener('click', sendMessage);
    messageInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') sendMessage();
    });

    function sendMessage() {
      const text = messageInput.value.trim();
      if (!text) return;

      // Usuario mensaje
      const userMsg = document.createElement('div');
      userMsg.className = 'mb-3 text-right';
      userMsg.innerHTML = `<div class="bg-gray-900 text-white rounded-lg px-4 py-2 inline-block max-w-xs">${text}</div>`;
      messagesDiv.appendChild(userMsg);

      messageInput.value = '';
      messagesDiv.scrollTop = messagesDiv.scrollHeight;

      // Generar respuesta automática inteligente
      setTimeout(() => {
        let response = getSmartResponse(text.toLowerCase());
        
        const botMsg = document.createElement('div');
        botMsg.className = 'mb-3';
        botMsg.innerHTML = `<div class="bg-gray-200 text-gray-900 rounded-lg px-4 py-2 inline-block max-w-xs text-sm">${response}</div>`;
        messagesDiv.appendChild(botMsg);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
      }, 500);
    }

    function getSmartResponse(message) {
      const responses = {
        email: "📧 Puedes enviarnos un email a: info@proyectoscsi.mx o samuel@proyectoscsi.mx",
        correo: "📧 Puedes enviarnos un email a: info@proyectoscsi.mx o samuel@proyectoscsi.mx",
        teléfono: "📞 Llámanos al: +52 33 4170 8104",
        llamar: "📞 Llámanos al: +52 33 4170 8104",
        número: "📞 Nuestro teléfono es: +52 33 4170 8104",
        ticket: "🎫 Puedes crear un ticket de soporte haciendo clic en el botón 'Crear Ticket de Soporte' o escribir a: samuel@proyectoscsi.mx",
        contacto: "📞 Disponemos de múltiples canales: email, teléfono y tickets de soporte. ¿Cuál prefieres?",
        disponibilidad: "✅ Estamos disponibles 24/7 para emergencias. Nuestro equipo responde en menos de 24 horas.",
        horario: "⏰ Nos encontramos disponibles todos los días. Respondemos en menos de 24 horas.",
        horas: "⏰ Respondemos a tus solicitudes lo antes posible, generalmente en minutos.",
        respuesta: "⏱️ Nuestro equipo usualmente responde en minutos. Garantizamos atención en menos de 24 horas.",
        problema: "🔧 Describe tu problema técnico y nuestro equipo experto te ayudará a resolverlo. info@proyectoscsi.mx - samuel@proyectoscsi.mx",
        técnico: "👨‍💻 Somos especialistas en soluciones técnicas. ¿En qué área necesitas ayuda?",
        solución: "💡 Ofrecemos múltiples canales de soporte: email, teléfono y tickets. ¿Cuál es tu consulta?",
        ayuda: "🤝 Claro que sí, aquí estamos para ayudarte. ¿Cuál es tu inconveniente?",
        problema_técnico: "🔧 Describe tu problema técnico y nuestro equipo especializado lo resolverá.",
        ciberseguridad: "🔒 Contamos con soluciones de ciberseguridad avanzadas. ¿Qué necesitas?",
        videovigilancia: "📹 Nuestras soluciones de videovigilancia son profesionales y confiables.",
        control_acceso: "🔐 Sistemas de control de acceso seguros y eficientes para tu empresa.",
        cableado: "🔌 Servicios de cableado estructurado de excelente calidad.",
        emergencia: "🚨 Para emergencias, llámanos inmediatamente al +52 33 4170 8104",
        urgente: "⚠️ Entiendemos que es urgente. Por favor, llama al +52 33 4170 8104 para atención inmediata.",
        equipo: "👥 Nuestro equipo está compuesto por técnicos especializados en todas las áreas.",
        especialista: "👨‍🔧 Todos nuestros técnicos son especialistas certificados en sus áreas.",
        precio: "💰 Para cotizaciones, por favor contacta con nuestro equipo de ventas.",
        costo: "💰 Nos encantaría ofrecerte una cotización. Contáctanos por email o teléfono.",
        gracias: "¡De nada! ¿Hay algo más en lo que podamos ayudarte?",
        thanks: "¡De nada! ¿Hay algo más en lo que podamos ayudarte?",
      };

      // Buscar palabras clave en el mensaje
      for (const [key, value] of Object.entries(responses)) {
        if (message.includes(key)) {
          return value;
        }
      }

      // Respuesta genérica por defecto
      const defaultResponses = [
        "Entiendo. Nuestro equipo de soporte te ayudará con tu consulta. ¿Puedes ser más específico?",
        "Gracias por tu mensaje. ¿Podrías detallar un poco más tu pregunta?",
        "Nos gustaría ayudarte. ¿Cuál es exactamente tu inconveniente?",
        "Para darte una mejor respuesta, ¿podrías contarnos más sobre tu problema?",
        "Claro, estamos aquí para ayudarte. ¿Qué necesitas?"
      ];
      
      return defaultResponses[Math.floor(Math.random() * defaultResponses.length)];
    }
  };

  // Inicializar chatbot cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initChatBot);
  } else {
    initChatBot();
  }
</script>

