<script>
  // Carrusel de componentes
  let currentComponenteSlide = 0;
  const totalComponenteSlides = 6;

  // @ts-ignore
  function moveComponentesCarousel(direction: number) {
    currentComponenteSlide = (currentComponenteSlide + direction + totalComponenteSlides) % totalComponenteSlides;
    updateComponentesCarousel();
  }

  // @ts-ignore
  function goToComponenteSlide(index: number) {
    currentComponenteSlide = index;
    updateComponentesCarousel();
  }

  function updateComponentesCarousel() {
    const track = document.querySelector('.carousel-track') as HTMLElement;
    const indicators = document.querySelectorAll('.carousel-indicator-componentes');
    
    if (track) {
      track.style.transform = `translateX(-${currentComponenteSlide * 100}%)`;
    }
    
    indicators.forEach((indicator, index) => {
      if (index === currentComponenteSlide) {
        indicator.classList.remove('bg-gray-300');
        indicator.classList.add('bg-gray-900');
      } else {
        indicator.classList.remove('bg-gray-900');
        indicator.classList.add('bg-gray-300');
      }
    });
  }

  // Auto-advance carousel every 5 seconds
  setInterval(() => {
    moveComponentesCarousel(1);
  }, 5000);

  // Make functions globally available
  // @ts-ignore
  window.moveComponentesCarousel = moveComponentesCarousel;
  // @ts-ignore
  window.goToComponenteSlide = goToComponenteSlide;

  // Toggle para tarjetas flip
  document.addEventListener('DOMContentLoaded', () => {
    const flipCards = document.querySelectorAll('.flip-card');
    flipCards.forEach(card => {
      card.addEventListener('click', () => {
        card.classList.toggle('flipped');
      });
    });
  });
</script>

<style>
  .flip-card {
    perspective: 1000px;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    transition: transform 0.6s;
    transform-style: preserve-3d;
  }

  /* Desktop: flip con hover */
  @media (min-width: 768px) {
    .flip-card:hover .flip-card-inner {
      transform: rotateY(180deg);
    }
  }

  /* Mobile: flip con clase .flipped (agregada por JavaScript) */
  @media (max-width: 767px) {
    .flip-card.flipped .flip-card-inner {
      transform: rotateY(180deg);
    }
  }

  .flip-card-front,
  .flip-card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    min-height: 400px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    top: 0;
    left: 0;
  }

  .flip-card-back {
    transform: rotateY(180deg);
  }

  @media (min-width: 768px) {
    .flip-card:hover {
      z-index: 10;
    }
  }

  @media (max-width: 767px) {
    .flip-card.flipped {
      z-index: 10;
    }
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }

  .flip-card-front svg:last-child {
    animation: pulse 2s ease-in-out infinite;
  }

  @media (max-width: 640px) {
    .flip-card,
    .flip-card-inner,
    .flip-card-front,
    .flip-card-back {
      min-height: 450px;
    }
  }
</style>
