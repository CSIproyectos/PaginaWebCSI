---
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import portadaImg from '@/img/sectores/mineria/portada.jpg';
import sensoresImg from '@/img/sectores/mineria/sensores.webp';
import mineria1Img from '@/img/sectores/mineria/mineria1.jpeg';
import mineria2Img from '@/img/sectores/mineria/mineria2.jpeg';

export const prerender = true;
---

<Layout title="Minería | Soluciones de Seguridad y Eficiencia | Proyectos CSI" description="Soluciones integrales de seguridad para minería: sistemas electrónicos, control de acceso, cámaras térmicas, infraestructura de red y conectividad inalámbrica.">
  <!-- Hero -->
  <section class="relative h-96 md:h-[28rem] bg-cover bg-center flex items-center justify-center overflow-hidden" style={`background-image: url(${portadaImg.src})`}>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative text-center text-white px-4 max-w-3xl drop-shadow-lg">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Seguridad y Eficiencia Para Operaciones Mineras</h1>
      <p class="text-lg md:text-xl text-gray-100">Tecnología avanzada que protege a tu personal, activos e instalaciones</p>
    </div>
  </section>

  <!-- Introducción con Galería -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">En Minería La Seguridad Es Fundamental</h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            En Proyectos CSI ofrecemos soluciones innovadoras que transforman la operación minera. Integramos <strong>sistemas de seguridad electrónica avanzada, control de acceso inteligente, infraestructura de red sólida y conectividad inalámbrica</strong> para garantizar protección, eficiencia y continuidad operativa en cada aspecto de tu operación.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed">
            Con tecnología de vanguardia adaptada a entornos mineros desafiantes, diseñamos soluciones que mejoran la seguridad del personal, optimizan procesos y permiten toma de decisiones en tiempo real.
          </p>
        </div>

        <!-- Galería de Imágenes Integrada -->
        <div class="mt-16 grid md:grid-cols-2 gap-12">
          <div class="text-center">
            <div class="rounded-3xl overflow-hidden shadow-2xl hover:shadow-3xl transition-all duration-300 group">
              <Image
                src={mineria1Img}
                alt="Operaciones mineras de seguridad"
                class="w-full h-80 md:h-96 object-cover object-top group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <p class="mt-6 text-lg font-semibold text-gray-900">Operaciones Mineras Seguras</p>
            <p class="mt-2 text-gray-600">Infraestructura integrada para monitoreo y control de operaciones en tiempo real</p>
          </div>
          <div class="text-center">
            <div class="rounded-3xl overflow-hidden shadow-2xl hover:shadow-3xl transition-all duration-300 group">
              <Image
                src={mineria2Img}
                alt="Infraestructura de seguridad minera"
                class="w-full h-80 md:h-96 object-cover object-top group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <p class="mt-6 text-lg font-semibold text-gray-900">Tecnología de Vigilancia Avanzada</p>
            <p class="mt-2 text-gray-600">Sistemas especializados para áreas críticas y acceso controlado</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Soluciones clave -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-5">Soluciones Clave Para Minería Moderna</h2>
        <p class="text-xl text-gray-700">
          Tecnología integrada para proteger personal, activos e instalaciones en entornos desafiantes.
        </p>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m7 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Sistemas de Seguridad Electrónica</h3>
            <p class="text-gray-600 leading-relaxed">
              Alarmas integradas, sensores especializados y monitoreo remoto. Protección completa de instalaciones mineras 24/7.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Control de Acceso Inteligente</h3>
            <p class="text-gray-600 leading-relaxed">
              Solo personal autorizado en áreas críticas. Reduce intrusiones, robos y mejora trazabilidad de operaciones.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Cámaras Especializadas</h3>
            <p class="text-gray-600 leading-relaxed">
              Visión térmica, radiométrica y sensores avanzados. Monitoreo completo en condiciones mineras extremas.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Infraestructura de Red Sólida</h3>
            <p class="text-gray-600 leading-relaxed">
              Cableado estructurado y arquitectura de red robusta. Conectividad confiable para sistemas críticos.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Monitoreo Remoto en Tiempo Real</h3>
            <p class="text-gray-600 leading-relaxed">
              Supervisa operaciones desde plataformas unificadas. Respuesta rápida ante incidencias, minimizando riesgos.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.72 11.492a8.25 8.25 0 0112.56 0M3.712 8.946a11.25 11.25 0 0116.576 0M12 20.25a.75.75 0 100-1.5.75.75 0 000 1.5z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Conectividad Inalámbrica</h3>
            <p class="text-gray-600 leading-relaxed">
              Comunicación fluida entre supervisores y personal. Trabajo seguro y eficiente en toda la operación.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- Sistemas de Seguridad Detallado -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Sistemas de Seguridad Electrónica Avanzada</h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            Nuestros sistemas de seguridad electrónica integran <strong>alarmas, sensores especializados y monitoreo remoto</strong> en plataformas unificadas. Protección completa y respuesta inmediata ante cualquier eventualidad.
          </p>
          <div class="space-y-4">
            <div class="bg-gray-50 p-4 rounded-lg">
              <h3 class="font-bold text-gray-900 mb-1">Automatización de Procesos</h3>
              <p class="text-gray-600">Reduce intervención manual y optimiza eficiencia operativa de forma continua.</p>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <h3 class="font-bold text-gray-900 mb-1">Sensores Especializados</h3>
              <p class="text-gray-600">Sensores de aire, cámaras térmicas y radiométricas, radares de perímetro.</p>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <h3 class="font-bold text-gray-900 mb-1">Supervisión Integral</h3>
              <p class="text-gray-600">Cada área protegida con administración centralizada y análisis en tiempo real.</p>
            </div>
          </div>
        </div>
        <div class="order-first lg:order-last">
          <img src={sensoresImg.src} alt="Sensores especializados de minería" class="rounded-2xl shadow-lg w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="section-padding bg-primary-900 text-white">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Beneficios de Trabajar Con Proyectos CSI</h2>
        <p class="text-xl text-primary-100">
          Transforma la seguridad y eficiencia de tu operación minera con soluciones integradas.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Mayor Seguridad del Personal</h3>
          <p class="text-primary-100">Prevención de accidentes y protección integral en entornos mineros desafiantes.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Monitoreo en Tiempo Real</h3>
          <p class="text-primary-100">Supervisa operaciones desde plataformas unificadas con respuesta inmediata.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Automatización de Procesos</h3>
          <p class="text-primary-100">Reduce intervención manual, optimiza eficiencia y reduce tiempos de inactividad.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Toma de Decisiones Informadas</h3>
          <p class="text-primary-100">Análisis de datos en tiempo real para mejora continua y gestión eficiente.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7H5v12h12V9m0-2h2a2 2 0 012 2v12a2 2 0 01-2 2h-2.5" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Cumplimiento Normativo</h3>
          <p class="text-primary-100">Conformidad con regulaciones de seguridad minera y trazabilidad completa.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 19H9a6 6 0 0112 0v1H9v-1a6 6 0 016-6" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Cultura de Seguridad</h3>
          <p class="text-primary-100">Ambiente colaborativo y conectado donde la seguridad es prioridad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          ¿Listo Para Transformar Tu Operación Minera?
        </h2>
        <p class="text-xl text-gray-600 mb-10">
          Contáctanos hoy para conocer soluciones personalizadas que protejan a tu personal, optimicen operaciones y mejoren rentabilidad. No esperes más para mejorar tu infraestructura y proteger tu inversión.
        </p>
        <a href="/contacto/" class="inline-block bg-primary-900 text-white px-8 py-3 md:px-10 md:py-4 rounded-lg font-semibold hover:bg-primary-800 transition-colors text-lg">
          Agendar Consulta Gratuita
        </a>
      </div>
    </div>
  </section>
</Layout>
