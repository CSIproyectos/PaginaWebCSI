---
import Layout from '@/layouts/Layout.astro';
import portadaImg from '@/img/sectores/logistica-recintos-fiscales/portadalogis.jpg';
import videoPlacas from '@/img/sectores/logistica-recintos-fiscales/videoplacas.mp4';

export const prerender = true;
---

<Layout title="Logística y Recintos Fiscales | Proyectos CSI" description="Soluciones integrales de seguridad, control y tecnología para optimizar logística y transporte. Videoseguridad, control de acceso, LPR/OCR y gestión de flotas en tiempo real.">
  <!-- Hero -->
  <section class="relative h-96 md:h-[28rem] bg-cover bg-center flex items-center justify-center overflow-hidden" style={`background-image: url(${portadaImg.src})`}>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative text-center text-white px-4 max-w-3xl drop-shadow-lg">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Soluciones Integrales Para Logística y Recintos Fiscales</h1>
      <p class="text-lg md:text-xl text-gray-100">Seguridad, conectividad y eficiencia operativa para tus instalaciones logísticas</p>
    </div>
  </section>

  <!-- Introducción -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">En Logística Cada Segundo Cuenta</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
          Ofrecemos soluciones integrales que garantizan la seguridad y eficiencia de tus operaciones logísticas. De la <strong>videoseguridad al reconocimiento inteligente de vehículos</strong>, pasando por control de acceso, infraestructura de red y gestión energética, integramos tecnología de vanguardia para salvaguardar instalaciones, optimizar recursos y acelerar la productividad.
        </p>
        <p class="text-lg text-gray-600 leading-relaxed">
          En un sector donde la precisión, la seguridad y la velocidad son competitivas, diseñamos soluciones escalables que mantienen continuidad operativa, reducen tiempos de inactividad y generan confianza en cada movimiento del negocio.
        </p>
      </div>
    </div>
  </section>

  <!-- Soluciones clave -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-5">Soluciones Clave Para Logística Moderna</h2>
        <p class="text-xl text-gray-700">
          Tecnología integrada para proteger activos, optimizar rutas y garantizar cumplimiento normativo en cada operación.
        </p>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Videoseguridad Alta Calidad</h3>
            <p class="text-gray-600 leading-relaxed">
              Vigilancia de vanguardia para prevenir accidentes, daños y pérdidas. Protege tu inversión y genera confianza en clientes.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Control de Acceso Inteligente</h3>
            <p class="text-gray-600 leading-relaxed">
              Perfiles y privilegios específicos para personal autorizado. Seguridad, eficiencia y trazabilidad en cada acceso.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Infraestructura de Red Robusta</h3>
            <p class="text-gray-600 leading-relaxed">
              Conectividad confiable y eficiente. Arquitectura diseñada para manejar datos sin interrupciones operativas.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.72 11.492a8.25 8.25 0 0112.56 0M3.712 8.946a11.25 11.25 0 0116.576 0M12 20.25a.75.75 0 100-1.5.75.75 0 000 1.5z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Conectividad Inalámbrica</h3>
            <p class="text-gray-600 leading-relaxed">
              Cobertura inalámbrica para códigos de barra, terminales móviles y tabletas. Productividad e inventario en tiempo real.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">LPR y OCR Inteligente</h3>
            <p class="text-gray-600 leading-relaxed">
              Reconocimiento de placas y contenedores. Gestión automática, optimización de rutas y aparcamientos eficientes.
            </p>
          </article>

          <article class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all">
            <svg class="w-12 h-12 text-primary-900 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 21h6m-3-3v3m-7-8h14M5 13V7a2 2 0 012-2h10a2 2 0 012 2v6" />
            </svg>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Energía y Sostenibilidad</h3>
            <p class="text-gray-600 leading-relaxed">
              Gestión energética optimizada. Reduce costos, mejora sostenibilidad y asegura disponibilidad continua.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- LPR y OCR Detallado -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Tecnología LPR y OCR Para Logística Inteligente</h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            Nuestro sistema de <strong>Reconocimiento de Placas (LPR)</strong> y <strong>Reconocimiento Óptico de Caracteres (OCR)</strong> transforma la operación logística. Identifica automáticamente vehículos, gestiona accesos sin contacto y optimiza aparcamientos de manera inteligente.
          </p>
          <div class="space-y-4">
            <div class="bg-gray-50 p-4 rounded-lg">
              <h3 class="font-bold text-gray-900 mb-1">Identificación Automática de Vehículos</h3>
              <p class="text-gray-600">Detecta placas y contenedores con precisión, eliminando errores manuales.</p>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <h3 class="font-bold text-gray-900 mb-1">Optimización de Rutas y Tiempos</h3>
              <p class="text-gray-600">Calcula tiempos de desplazamiento y planifica rutas más eficientes automáticamente.</p>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <h3 class="font-bold text-gray-900 mb-1">Gestión de Acceso y Seguridad</h3>
              <p class="text-gray-600">Autoriza solo vehículos registrados, mejorando control y seguridad perimetral.</p>
            </div>
          </div>
        </div>
        <div class="order-first lg:order-last">
          <video 
            src={videoPlacas}
            autoplay 
            loop 
            muted 
            playsinline
            class="rounded-2xl shadow-lg w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="section-padding bg-primary-900 text-white">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Beneficios de Trabajar Con Proyectos CSI</h2>
        <p class="text-xl text-primary-100">
          Integramos seguridad, eficiencia y tecnología para que tu logística sea más rápida, segura y rentable.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Mayor Seguridad</h3>
          <p class="text-primary-100">Protección perimetral, control de acceso y vigilancia continua de todas operaciones.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Optimización de Rutas</h3>
          <p class="text-primary-100">Reduce tiempos de operación y costos de combustible con inteligencia LPR/OCR.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Gestión de Inventario</h3>
          <p class="text-primary-100">Conectividad inalámbrica y registro automático para control de stock en tiempo real.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Reducción de Costos</h3>
          <p class="text-primary-100">Optimización energética, automatización y eficiencia operativa disminuyen gastos.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7H5v12h12V9m0-2h2a2 2 0 012 2v12a2 2 0 01-2 2h-2.5" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Cumplimiento Normativo</h3>
          <p class="text-primary-100">Trazabilidad, registros auditables y conformidad con regulaciones logísticas.</p>
        </div>
        <div class="bg-white/10 rounded-xl p-6">
          <svg class="w-10 h-10 text-white mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 19H9a6 6 0 0112 0v1H9v-1a6 6 0 016-6" />
          </svg>
          <h3 class="text-xl font-bold mb-2">Satisfacción del Cliente</h3>
          <p class="text-primary-100">Entregas confiables, transparencia y productos en perfectas condiciones.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          ¿Listo Para Transformar Tu Logística?
        </h2>
        <p class="text-xl text-gray-600 mb-10">
          Contáctanos hoy para una consulta gratuita. Descubre cómo nuestras soluciones integradas pueden optimizar operaciones, aumentar seguridad y rentabilidad en tu empresa de logística y recintos fiscales.
        </p>
        <a href="/contacto" class="inline-block bg-primary-900 text-white px-8 py-3 md:px-10 md:py-4 rounded-lg font-semibold hover:bg-primary-800 transition-colors text-lg">
          Agendar Consulta Gratuita
        </a>
      </div>
    </div>
  </section>
</Layout>
