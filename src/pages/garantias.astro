---
import Layout from '@/layouts/Layout.astro';
import garantiasImg from '@/img/garantia/portada.webp';
import soporteImg from '@/img/Soporte-3.webp';
---

<Layout
  title="Políticas de Garantía | Proyectos CSI"
  description="Conoce nuestras políticas de garantía. Cobertura de equipos, instalación y soporte técnico. Garantías claras, justas y sin complicaciones."
>
  <!-- Hero -->
  <section class="relative h-80 md:h-96 flex items-center justify-center overflow-hidden" style={`background-image: url(${garantiasImg.src}); background-size: cover; background-position: center;`}>
    <div class="absolute inset-0 bg-black/75"></div>
    <div class="relative text-center text-white px-4 max-w-3xl z-10">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 drop-shadow-lg">Políticas de Garantía</h1>
      <p class="text-lg md:text-xl text-gray-100 drop-shadow">Sin complicaciones</p>
    </div>
  </section>

  <!-- Solicitar Garantías -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Solicitar Garantías de Proyectos CSI
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed">
          En <span class="font-semibold">Proyectos CSI</span>, respaldamos la calidad de cada solución que diseñamos e implementamos. Nuestro compromiso es garantizar el rendimiento y la continuidad de tus operaciones a través de un soporte claro, justo y eficiente.
        </p>
      </div>
    </div>
  </section>

  <!-- Puntos Clave -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Puntos Clave de Nuestra Garantia
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        <!-- 30 días -->
        <div class="bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow">
          <div class="text-4xl font-bold text-gray-900 mb-3">30</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">días de garantía total</h3>
          <p class="text-sm text-gray-600">
            En nuestra instalación y mano de obra.
          </p>
        </div>

        <!-- Gestión -->
        <div class="bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow">
          <svg class="w-12 h-12 mx-auto mb-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
          </svg>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Gestionamos por ti</h3>
          <p class="text-sm text-gray-600">
            Gestión de garantía de los equipos directamente con fabricantes.
          </p>
        </div>

        <!-- Soporte -->
        <div class="bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow">
          <svg class="w-12 h-12 mx-auto mb-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
          </svg>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Soporte técnico ágil</h3>
          <p class="text-sm text-gray-600">
            Diagnóstico rápido y eficiente.
          </p>
        </div>

        <!-- Proceso -->
        <div class="bg-white rounded-lg p-6 text-center hover:shadow-lg transition-shadow">
          <svg class="w-12 h-12 mx-auto mb-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
          </svg>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Proceso claro y transparente</h3>
          <p class="text-sm text-gray-600">
            Información sobre el estado de tu caso.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cobertura de la Garantía -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Cobertura de la Garantía
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Equipos y Componentes -->
        <div class="bg-gray-50 rounded-lg p-8">
          <h3 class="text-xl font-bold text-white bg-gray-700 p-4 rounded-t-lg -m-8 mb-6">
            Garantía sobre Equipos y Componentes
          </h3>
          <p class="text-sm font-semibold text-gray-900 mb-6">
            Directa del Fabricante
          </p>

          <ul class="space-y-3">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-gray-900 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Todos los equipos principales están cubiertos por la garantía directa de su respectivo fabricante.</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-gray-900 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700"><strong>Duración:</strong> De 1 a 5 años dependiendo de la marca y número de serie.</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-gray-900 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Proyectos CSI actúa como gestor e intermediario para facilitar el proceso de reclamación con la marca, asegurando una solución ágil para ti.</span>
            </li>
          </ul>

          <div class="mt-8 bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
            <h4 class="font-bold text-gray-900 mb-2">Equipos cubiertos:</h4>
            <ul class="space-y-1 text-sm text-gray-700">
              <li>• Access Point</li>
              <li>• Cámaras de seguridad</li>
              <li>• Sistemas de control de acceso</li>
            </ul>
          </div>
        </div>

        <!-- Instalación y Mano de Obra -->
        <div class="bg-gray-50 rounded-lg p-8">
          <h3 class="text-xl font-bold text-white bg-gray-700 p-4 rounded-t-lg -m-8 mb-6">
            Garantía sobre Instalación y Mano de Obra
          </h3>
          <p class="text-sm font-semibold text-gray-900 mb-6">
            Directa de CSI
          </p>

          <div class="bg-blue-50 rounded p-4 mb-6">
            <div class="flex items-center justify-center">
              <svg class="w-8 h-8 text-gray-900 mr-3" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-13c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5z"/>
              </svg>
              <span class="text-gray-900 font-bold">30 días (1 mes): A partir de la fecha de finalización del proyecto</span>
            </div>
          </div>

          <ul class="space-y-3">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-gray-900 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700"><strong>Cualquier defecto en la mano de obra</strong></span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-gray-900 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700"><strong>Conexiones y cableado</strong></span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-gray-900 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700"><strong>Montaje de equipos</strong></span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-gray-900 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700"><strong>Correcta integración de todos los componentes del sistema</strong></span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso para Solicitar -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Proceso para Solicitar una Garantía
        </h2>
        <p class="text-lg text-gray-600">
          Sigue estos sencillos pasos para iniciar el proceso de garantía
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-8">
        <!-- Paso 1 -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
          <div class="md:col-span-2 flex justify-center">
            <div class="flex items-center justify-center w-16 h-16 rounded-full bg-gray-900 text-white font-bold text-2xl">
              1
            </div>
          </div>
          <div class="md:col-span-10">
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Levantar un Reporte</h3>
            <p class="text-gray-600 mb-4">
              Notifica a nuestro equipo de soporte técnico a través de los canales oficiales, proporcionando el número de contrato o factura y una descripción detallada de la falla observada.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-white p-4 rounded border border-gray-200">
                <p class="text-sm font-bold text-gray-700 mb-1">Correo de Soporte</p>
                <p class="text-gray-600">ingenieria@proyectoscsi.mx</p>
              </div>
              <div class="bg-white p-4 rounded border border-gray-200">
                <p class="text-sm font-bold text-gray-700 mb-1">Teléfono de Atención</p>
                <p class="text-gray-600">+52 33 4170 8104</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Paso 2 -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
          <div class="md:col-span-2 flex justify-center">
            <div class="flex items-center justify-center w-16 h-16 rounded-full bg-gray-900 text-white font-bold text-2xl">
              2
            </div>
          </div>
          <div class="md:col-span-10">
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Diagnóstico Inicial</h3>
            <p class="text-gray-600">
              Nuestro equipo realizará un diagnóstico inicial al equipo de forma de monitoreo. Si no es posible identificar la causa, se agendará una visita técnica a tus instalaciones.
            </p>
          </div>
        </div>

        <!-- Paso 3 -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
          <div class="md:col-span-2 flex justify-center">
            <div class="flex items-center justify-center w-16 h-16 rounded-full bg-gray-900 text-white font-bold text-2xl">
              3
            </div>
          </div>
          <div class="md:col-span-10">
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Ejecución de la Garantía</h3>
            <p class="text-gray-600 mb-4">
              Una vez confirmado que la falla está cubierta:
            </p>
            <div class="space-y-3">
              <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
                <p class="font-bold text-gray-900">Si el problema es de instalación:</p>
                <p class="text-gray-700">Nuestro personal técnico lo corregirá.</p>
              </div>
              <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
                <p class="font-bold text-gray-900">Si el problema es de un equipo:</p>
                <p class="text-gray-700">Iniciaremos el proceso de garantía con el fabricante para su reparación o reemplazo.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-200 p-4 rounded-lg mt-6">
          <p class="text-gray-900 font-semibold">
            <strong>Nota:</strong> En casos de garantía, el envío del equipo corre por cuenta del cliente; el envío de regreso será cubierto por Proyectos CSI.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tiempos de Respuesta -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Tiempos de Respuesta y Solución
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Diagnóstico -->
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">• Diagnóstico</h3>
          <p class="text-gray-600 mb-6">
            Iniciaremos el proceso de diagnóstico de manera inmediata tras recibir tu reporte. Nuestro compromiso es emitir una evaluación preliminar de la causa raíz en un plazo máximo de:
          </p>
          <div class="bg-gray-900 text-white rounded-lg p-6 text-center">
            <p class="text-3xl font-bold">48 horas hábiles</p>
          </div>
          <p class="text-gray-600 mt-4 text-sm">
            Este tiempo nos permite realizar las pruebas necesarias para definir la ruta de acción más efectiva.
          </p>
        </div>

        <!-- Solución -->
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">• Solución</h3>
          <p class="text-gray-600 mb-6">
            El tiempo para la solución definitiva dependerá de la complejidad del problema:
          </p>
          <div class="space-y-3">
            <div class="bg-gray-100 p-4 rounded-lg">
              <h4 class="font-bold text-gray-900 mb-2">Correcciones de Instalación</h4>
              <p class="text-gray-700 text-sm">Se realizarán a la mayor brevedad posible.</p>
            </div>
            <div class="bg-gray-100 p-4 rounded-lg">
              <h4 class="font-bold text-gray-900 mb-2">Garantías de Equipos</h4>
              <p class="text-gray-700 text-sm">Están sujetas a los tiempos de respuesta y logística de los fabricantes.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué NO Cubre -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          ¿Qué NO Cubre la Garantía?
        </h2>
        <p class="text-lg text-gray-600">
          La garantía no será aplicable en las siguientes situaciones
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        <div class="bg-white border-l-4 border-red-500 p-6 rounded-lg">
          <h3 class="font-bold text-gray-900 text-lg mb-2">Fenómenos naturales</h3>
          <p class="text-gray-700">Descargas eléctricas atmosféricas (rayos), inundaciones, terremotos, incendios.</p>
        </div>

        <div class="bg-white border-l-4 border-red-500 p-6 rounded-lg">
          <h3 class="font-bold text-gray-900 text-lg mb-2">Problemas eléctricos</h3>
          <p class="text-gray-700">Fallas derivadas de variaciones externas de voltaje o anomalías en la red eléctrica pública (CFE).</p>
        </div>

        <div class="bg-white border-l-4 border-red-500 p-6 rounded-lg">
          <h3 class="font-bold text-gray-900 text-lg mb-2">Mal uso o negligencia</h3>
          <p class="text-gray-700">Daños por mal uso, negligencia, accidentes o no seguir las recomendaciones de operación del sistema.</p>
        </div>

        <div class="bg-white border-l-4 border-red-500 p-6 rounded-lg">
          <h3 class="font-bold text-gray-900 text-lg mb-2">Modificaciones no autorizadas</h3>
          <p class="text-gray-700">Cualquier modificación, reparación o reubicación del sistema realizada por personal no autorizado por Proyectos CSI.</p>
        </div>

        <div class="bg-white border-l-4 border-red-500 p-6 rounded-lg">
          <h3 class="font-bold text-gray-900 text-lg mb-2">Desgaste normal</h3>
          <p class="text-gray-700">Desgaste estético o normal de los componentes que no afecta su funcionamiento y rendimiento.</p>
        </div>

        <div class="bg-white border-l-4 border-red-500 p-6 rounded-lg">
          <h3 class="font-bold text-gray-900 text-lg mb-2">Falta de mantenimiento</h3>
          <p class="text-gray-700">Fallas causadas por la omisión del mantenimiento preventivo recomendado, si este fue definido en el contrato de servicio.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="section-padding bg-gray-900 text-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          ¿Tienes dudas sobre tu garantía?
        </h2>
        <p class="text-xl text-gray-300 mb-10">
          Contáctanos y nuestro equipo te asesorará sobre la cobertura de tu solución.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:+5233417081041"
            class="inline-flex items-center justify-center px-8 py-4 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors"
          >
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Llamar Ahora
          </a>
          <a
            href="mailto:info@proyectoscsi.mx,samuel@proyectoscsi.mx"
            class="inline-flex items-center justify-center px-8 py-4 bg-gray-700 text-white font-bold rounded-lg hover:bg-gray-600 transition-colors"
          >
            ✉️ Enviar Email
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Levanta un Ticket de Soporte -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
        <!-- Imagen -->
        <div class="flex justify-center">
          <img 
            src={soporteImg.src} 
            alt="Soporte Técnico" 
            class="max-w-full h-auto"
            width="400"
            height="400"
          />
        </div>

        <!-- Contenido -->
        <div class="text-center lg:text-left">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">
            Levanta un Ticket de Soporte
          </h2>
          
          <button 
            onclick="openSupportTicket()"
            class="inline-block px-8 py-4 bg-gray-900 text-white font-bold rounded-full hover:bg-gray-800 transition-colors mb-8"
          >
            Crear Ticket de Soporte
          </button>

          <p class="text-lg text-gray-600">
            <span class="font-semibold text-gray-900">Tiempo de respuesta:</span>
            <br>
            Nuestro equipo atenderá tu solicitud lo antes posible.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-padding {
    @apply py-16 px-6;
  }

  .container-custom {
    @apply max-w-7xl mx-auto;
  }
</style>
