---
import Layout from '@/layouts/Layout.astro';
import portadaImg from '@/img/sectores/corporativo/portada.jpg';
import videoVigilanciaImg from '@/img/sectores/corporativo/videoVigilancia.jpg';
import controlAccesoImg from '@/img/sectores/corporativo/controlAcceso.mp4';
import infraestructuraRedImg from '@/img/sectores/corporativo/infrastructuraRed.jpg';
---

<Layout
  title="Sector Corporativo - Proyectos CSI"
  description="Soluciones innovadoras de videovigilancia, control de acceso y conectividad para empresas corporativas."
>
  <!-- Hero -->
  <section class="relative text-white py-32 md:py-40 overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src={portadaImg.src} 
        alt="Sector Corporativo" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative container-custom text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 drop-shadow-2xl">Sector Corporativo</h1>
      <p class="text-xl md:text-2xl text-white max-w-3xl mx-auto drop-shadow-lg">
        Soluciones innovadoras que transforman la seguridad y eficiencia operativa de tu empresa
      </p>
    </div>
  </section>

  <!-- Introducción -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-xl text-gray-700 leading-relaxed">
          En Proyectos CSI nos especializamos en ofrecer soluciones innovadoras que transforman la operación en el sector corporativo. 
          Nuestra experiencia se centra en la implementación de tecnologías avanzadas que mejoran la <strong>seguridad</strong> y la <strong>eficiencia operativa</strong>, 
          garantizando la protección del personal y las instalaciones en todo momento.
        </p>
      </div>
    </div>
  </section>

  <!-- Sistemas de Videovigilancia -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center justify-center mb-6">
            <svg class="w-16 h-16 text-primary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Sistemas de Videovigilancia</h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            Nuestras soluciones integran alarmas, control de acceso y monitoreo remoto, proporcionando un enfoque completo para la protección de instalaciones corporativas.
          </p>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Tecnología Avanzada:</h3>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-gray-900 mr-3 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Sensores de condición del aire para ambientes seguros</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-gray-900 mr-3 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Cámaras multisensor para cobertura completa</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-gray-900 mr-3 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Analíticos situacionales y de prevención de intrusiones</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-gray-900 mr-3 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Plataformas unificadas para gestión centralizada</span>
            </li>
          </ul>
          <p class="text-gray-600 leading-relaxed">
            El monitoreo remoto en tiempo real permite a los responsables de seguridad supervisar las instalaciones continuamente, 
            facilitando la identificación de incidentes y la toma de decisiones informadas.
          </p>
        </div>
        <div class="relative h-96 rounded-2xl shadow-2xl overflow-hidden">
          <img 
            src={videoVigilanciaImg.src} 
            alt="Sistemas de Videovigilancia" 
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Controles de Acceso -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 relative h-96 rounded-2xl shadow-2xl overflow-hidden">
          <video 
            src={controlAccesoImg} 
            autoplay
            loop
            muted
            playsinline
            class="w-full h-full object-cover"
          >
            Tu navegador no soporta videos.
          </video>
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center justify-center mb-6">
            <svg class="w-16 h-16 text-primary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Controles de Acceso</h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            El control de acceso avanzado asegura que solo el personal autorizado tenga acceso a áreas críticas, 
            disminuyendo las posibilidades de intrusiones y robos.
          </p>
          <div class="space-y-4 mb-6">
            <div class="bg-gray-50 p-4 rounded-lg">
              <h4 class="font-bold text-gray-900 mb-2">Protección Multicapa</h4>
              <p class="text-gray-600">Sistemas de alarmas integrados que alertan al personal de seguridad ante cualquier actividad sospechosa.</p>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <h4 class="font-bold text-gray-900 mb-2">Análisis Continuo</h4>
              <p class="text-gray-600">Recopilación y análisis de datos para identificar patrones, áreas de mejora y optimización de recursos.</p>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <h4 class="font-bold text-gray-900 mb-2">Cultura de Seguridad</h4>
              <p class="text-gray-600">Fomentamos una cultura organizacional donde todos los empleados son conscientes de la importancia de la protección.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Infraestructura de Red -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center justify-center mb-6">
            <svg class="w-16 h-16 text-primary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Infraestructura y Arquitectura de Red</h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            La infraestructura y arquitectura de red son fundamentales para garantizar una operación eficiente y segura. 
            Implementamos sistemas de cableado estructurado que proporcionan una base sólida para la conectividad.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div class="flex items-start">
              <div class="w-10 h-10 flex items-center justify-center mr-3 flex-shrink-0">
                <svg class="w-10 h-10 text-primary-900" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 mb-1">Escalabilidad</h4>
                <p class="text-gray-600 text-sm">Red que se expande según las necesidades cambiantes</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="w-10 h-10 flex items-center justify-center mr-3 flex-shrink-0">
                <svg class="w-10 h-10 text-primary-900" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 mb-1">Alta Velocidad</h4>
                <p class="text-gray-600 text-sm">Transmisión de datos rápida y confiable</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="w-10 h-10 flex items-center justify-center mr-3 flex-shrink-0">
                <svg class="w-10 h-10 text-primary-900" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 mb-1">Monitoreo 24/7</h4>
                <p class="text-gray-600 text-sm">Control continuo del tráfico de datos</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="w-10 h-10 flex items-center justify-center mr-3 flex-shrink-0">
                <svg class="w-10 h-10 text-primary-900" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 mb-1">Continuidad</h4>
                <p class="text-gray-600 text-sm">Minimiza tiempo de inactividad</p>
              </div>
            </div>
          </div>
          <p class="text-gray-600 leading-relaxed">
            Contar con una red que ofrezca visibilidad y control en tiempo real es esencial para mejorar la comunicación entre equipos 
            y garantizar una respuesta rápida ante cualquier eventualidad.
          </p>
        </div>
        <div class="relative h-96 rounded-2xl shadow-2xl overflow-hidden">
          <img 
            src={infraestructuraRedImg.src} 
            alt="Infraestructura y Arquitectura de Red" 
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Conectividad Inalámbrica -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center mb-6">
          <svg class="w-20 h-20 text-primary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />
          </svg>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Conectividad Inalámbrica de Última Generación</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto mb-12 leading-relaxed">
          Creamos un entorno de conectividad que permite una comunicación fluida y productiva en todos los espacios de tu empresa.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        <div class="bg-white p-8 rounded-2xl border-2 border-primary-100 hover:border-primary-300 hover:shadow-xl transition-all">
          <div class="flex items-center justify-center mb-6">
            <svg class="w-16 h-16 text-primary-600" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3.5A5.5 5.5 0 003.5 9a5.5 5.5 0 005.5 5.5A5.5 5.5 0 0014.5 9 5.5 5.5 0 009 3.5zM15 3.5A5.5 5.5 0 009.5 9a5.5 5.5 0 005.5 5.5A5.5 5.5 0 0020.5 9 5.5 5.5 0 0015 3.5zM9 9.5A5.5 5.5 0 003.5 15a5.5 5.5 0 005.5 5.5A5.5 5.5 0 0014.5 15 5.5 5.5 0 009 9.5zM15 9.5A5.5 5.5 0 009.5 15a5.5 5.5 0 005.5 5.5 5.5 5.5 0 005.5-5.5 5.5 5.5 0 00-5.5-5.5z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center">Redes Mesh</h3>
          <p class="text-gray-600 text-center leading-relaxed">Múltiples puntos de acceso conectados entre sí, eliminando zonas muertas y asegurando cobertura total en todas las áreas.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl border-2 border-blue-100 hover:border-blue-300 hover:shadow-xl transition-all">
          <div class="flex items-center justify-center mb-6">
            <svg class="w-16 h-16 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center">WiFi 6 & 6E</h3>
          <p class="text-gray-600 text-center leading-relaxed">Velocidades ultrarrápidas y mayor capacidad con banda de 6 GHz para múltiples dispositivos sin interferencias.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl border-2 border-purple-100 hover:border-purple-300 hover:shadow-xl transition-all">
          <div class="flex items-center justify-center mb-6">
            <svg class="w-16 h-16 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3 text-center">WiFi 7</h3>
          <p class="text-gray-600 text-center leading-relaxed">Próxima generación con mejoras revolucionarias en velocidad, latencia ultra baja y capacidad masiva de dispositivos.</p>
        </div>
      </div>

      <div class="bg-gray-100 rounded-2xl p-10 text-center border-2 border-gray-200">
        <svg class="w-12 h-12 mx-auto mb-4 text-primary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-2xl font-bold mb-3 text-gray-900">
          La movilidad y conectividad constante son esenciales para la productividad
        </p>
        <p class="text-xl font-medium text-gray-800">
          Nuestra infraestructura garantiza que tu empresa esté preparada para el futuro
        </p>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="section-padding bg-primary-900 text-white">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Beneficios de trabajar con Proyectos CSI</h2>
        <p class="text-xl text-primary-100 max-w-3xl mx-auto">
          Impacto positivo medible en la operación corporativa
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 hover:bg-white/20 transition-colors">
          <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Mayor Productividad</h3>
          <p class="text-primary-100">Optimización de procesos que se traduce en reducción de tiempos de inactividad y mayor eficiencia operativa.</p>
        </div>

        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 hover:bg-white/20 transition-colors">
          <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Seguridad Mejorada</h3>
          <p class="text-primary-100">Monitoreo constante que contribuye a la prevención de accidentes y protección del personal e instalaciones.</p>
        </div>

        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 hover:bg-white/20 transition-colors">
          <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Colaboración Efectiva</h3>
          <p class="text-primary-100">Ambiente conectado que facilita la toma de decisiones informadas y rápidas entre equipos.</p>
        </div>

        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 hover:bg-white/20 transition-colors">
          <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Gestión Eficiente</h3>
          <p class="text-primary-100">Mejor administración de recursos y mejora continua en la operación corporativa.</p>
        </div>

        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 hover:bg-white/20 transition-colors">
          <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Optimización de Costos</h3>
          <p class="text-primary-100">Inversión inteligente que reduce gastos operativos y protege activos valiosos.</p>
        </div>

        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 hover:bg-white/20 transition-colors">
          <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
