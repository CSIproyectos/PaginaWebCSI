
---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../img/soluciones/videovigilancia/IMG_0192.webp';
import logoGenetec from '../img/soluciones/videovigilancia/1-300x180.webp';
import logoHanwha from '../img/soluciones/videovigilancia/2-1-300x180.webp';
import logoFLIR from '../img/soluciones/videovigilancia/3-1-300x180.webp';
import logoVaelsys from '../img/soluciones/videovigilancia/4-1-300x180.webp';
import casoManzanillo from '../img/casos/Termina-Manzanillo.webp';
import casoHotel from '../img/casos/portobelo-hotel.webp';
import casoAifa from '../img/casos/aifa-1.webp';
import casoPlanta from '../img/casos/Planta-de-cemento-tecoman.webp';
---

<Layout 
  title="Videovigilancia y cámaras de seguridad en Manzanillo | CSI"
  description="Cámaras de seguridad para empresas en México. Instalación de sistemas CCTV, monitoreo remoto y analíticos con IA. Solicita cotización en GDL, Colima y todo el país."
>
  <!-- Hero Section -->
  <section class="relative h-[60vh] min-h-[500px] flex items-center justify-start overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImage}
        alt="Sistema de videovigilancia"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-transparent"></div>
    </div>
    
    <div class="container-custom relative z-10 text-white px-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">
        Cámaras de Seguridad y Videovigilancia
      </h1>
      <p class="text-xl md:text-2xl max-w-2xl">
        Inteligente y Unificado para Operaciones Críticas
      </p>
    </div>
  </section>

  <!-- Sección: Más allá de las cámaras -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <h2 class="text-center mb-6 text-gray-900">Más que cámaras: sistemas de videovigilancia y CCTV para proteger tu empresa</h2>
      
      <div class="text-center text-gray-700 text-lg mb-16 max-w-4xl mx-auto space-y-6">
        <p class="leading-relaxed">
          En Proyectos CSI diseñamos e implementamos sistemas de videovigilancia profesional para empresas, integrando cámaras de seguridad CCTV, analíticos con inteligencia artificial y plataformas unificadas de monitoreo.
        </p>
        
        <p class="leading-relaxed">
          Nuestras soluciones van más allá de la instalación de cámaras de seguridad: desarrollamos sistemas completos de circuito cerrado (CCTV) que permiten prevenir intrusiones, supervisar operaciones y mantener el control en tiempo real.
        </p>
        
        <p class="leading-relaxed">
          Ya sea en entornos industriales, logísticos o corporativos, ayudamos a las empresas a mejorar su seguridad, eficiencia operativa y capacidad de respuesta ante incidentes.
        </p>

        <h3 class="font-semibold text-primary-900 text-xl mt-8 text-center">
          Beneficios de implementar un sistema de cámaras de seguridad profesional
        </h3>
        
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
        <!-- Seguridad patrimonial -->
        <div class="text-center">
          <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-gray-900">Seguridad patrimonial</h3>
          <p class="text-gray-600 leading-relaxed">
            Protege tus activos mediante sistemas de videovigilancia con detección de intrusiones y monitoreo en tiempo real.
          </p>
        </div>

        <!-- Salud y Seguridad -->
        <div class="text-center">
          <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-gray-900">Salud y Seguridad (H&S)</h3>
          <p class="text-gray-600 leading-relaxed">
            Supervisa áreas críticas y cumple con normativas mediante cámaras de seguridad y analítica de video.
          </p>
        </div>

        <!-- Operaciones -->
        <div class="text-center">
          <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-gray-900">Operaciones</h3>
          <p class="text-gray-600 leading-relaxed">
            Mejora tus procesos logísticos, supervisa la producción y disfruta de una trazabilidad visual que te permitirá tener todo bajo control.
          </p>
        </div>

        <!-- TI -->
        <div class="text-center">
          <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-gray-900">TI</h3>
          <p class="text-gray-600 leading-relaxed">
            Implementamos sistemas seguros con protocolos encriptados, compatibles con estándares internacionales.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cobertura local -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="inline-flex items-center rounded-full bg-gray-200 px-4 py-2 text-sm font-semibold text-gray-900 mb-6">
            Videovigilancia en Manzanillo, Colima
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Cámaras de seguridad para empresas, industria y puertos en México
          </h2>
          <div class="space-y-4 text-gray-700 leading-relaxed text-lg">
            <p>
              Si buscas <strong class="text-gray-900">instalación de cámaras de seguridad para empresas</strong>, diseñamos soluciones de videovigilancia adaptadas a entornos industriales, logísticos y corporativos.
            </p>
            <p>
              Implementamos sistemas de circuito cerrado (CCTV) que combinan monitoreo perimetral, analíticos de video y grabación centralizada para proteger accesos, almacenes, patios de maniobra y áreas críticas de operación.
            </p>
            <p>
              Contamos con experiencia en terminales portuarias, recintos fiscales, plantas industriales y hoteles, desarrollando proyectos de videovigilancia robustos, escalables y con mantenimiento especializado.
            </p>
            <p>  
              Brindamos servicio en Manzanillo, Colima y proyectos en toda la República Mexicana, incluyendo Guadalajara, Ciudad de México y Querétaro.            
            </p>
            
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Soluciones de videovigilancia más solicitadas</h3>
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start gap-3">
              <span class="mt-1 h-2.5 w-2.5 rounded-full bg-gray-900 flex-shrink-0"></span>
              <span>Videovigilancia perimetral para terminales portuarias y centros logísticos.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 h-2.5 w-2.5 rounded-full bg-gray-900 flex-shrink-0"></span>
              <span>Sistemas de cámaras IP con monitoreo remoto para empresas.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 h-2.5 w-2.5 rounded-full bg-gray-900 flex-shrink-0"></span>
              <span>Instalación de cámaras de seguridad para negocios e industria.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 h-2.5 w-2.5 rounded-full bg-gray-900 flex-shrink-0"></span>
              <span>Integración de CCTV con control de acceso, analíticos e inteligencia artificial.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Tecnología de clase mundial -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <h2 class="text-center mb-6 text-gray-900">Tecnología de videovigilancia profesional con fabricantes líderes</h2>
      <p class="text-center text-gray-700 text-lg mb-16 leading-relaxed max-w-3xl mx-auto">
        Trabajamos con fabricantes de clase mundial para implementar sistemas de videovigilancia y cámaras de seguridad profesionales, garantizando soluciones robustas, escalables y de alta precisión para empresas.
        <br><br>Integramos plataformas avanzadas de CCTV, analítica de video y monitoreo centralizado, adaptadas a entornos industriales, logísticos y corporativos.
      </p>

      <div class="grid md:grid-cols-2 gap-10 max-w-6xl mx-auto">
        <!-- Genetec -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <div class="mb-8 flex justify-center">
            <Image src={logoGenetec} alt="Genetec" class="h-32 w-auto object-contain" />
          </div>
          <p class="text-gray-700 leading-loose text-base">
            Genetec es una plataforma de videovigilancia unificada que combina una serie de funcionalidades avanzadas, incluyendo analíticos, videowall, control de acceso, reconocimiento de matrículas (LPR) y gestión tanto desde la nube como desde el sitio físico.
          </p>
          <p class="text-gray-700 leading-loose text-base mt-4">
            Nos enorgullecemos de ser integradores certificados, lo que garantiza que ofrecemos soluciones de alta calidad y rendimiento.
          </p>
        </div>

        <!-- Hanwha Vision -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <div class="mb-8 flex justify-center">
            <Image src={logoHanwha} alt="Hanwha Vision" class="h-32 w-auto object-contain" />
          </div>
          <p class="text-gray-700 leading-loose text-base">
            Hanwha Vision se especializa en cámaras equipadas con inteligencia artificial, que utilizan técnicas de deep learning para mejorar la detección de anomalías y proporcionar una visión avanzada.
          </p>
          <p class="text-gray-700 leading-loose text-base mt-4">
            Estas cámaras son especialmente eficientes gracias a su tecnología de compresión H.265, que optimiza el uso del ancho de banda y el almacenamiento. También somos integradores certificados de esta tecnología.
          </p>
        </div>

        <!-- Vaelsys -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <div class="mb-8 flex justify-center">
            <Image src={logoVaelsys} alt="Vaelsys" class="h-32 w-auto object-contain" />
          </div>
          <p class="text-gray-700 leading-loose text-base">
            Vaelsys ofrece una analítica de video avanzada que permite la clasificación de eventos, la detección de intrusos y la automatización de procesos, mejorando así la seguridad y la eficiencia operativa en diversas aplicaciones.
          </p>
        </div>

        <!-- FLIR -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <div class="mb-8 flex justify-center">
            <Image src={logoFLIR} alt="FLIR" class="h-32 w-auto object-contain" />
          </div>
          <p class="text-gray-700 leading-loose text-base">
            FLIR se dedica a la producción de cámaras térmicas y radiométricas, diseñadas específicamente para el monitoreo de temperatura en áreas críticas y para la prevención de incendios.
          </p>
          <p class="text-gray-700 leading-loose text-base mt-4">
            Al igual que con nuestras otras soluciones, somos integradores certificados, lo que respalda nuestra capacidad para implementar estas tecnologías de manera efectiva.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mira el panorama completo -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Texto -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Observa el panorama completo.<br>
            <span class="text-gray-700">Disfruta de una interfaz potente.</span>
          </h2>
          
          <div class="space-y-6 text-gray-700 leading-relaxed">
            <p>
              La interfaz unificada centraliza toda tu operación mediante dashboards personalizables y mapas dinámicos. Integra en una sola pantalla transmisiones de video, analítica de control de aforo (conteo de personas) y sensores críticos.
            </p>
            
            <p>
              Monitorea actividades y optimiza la respuesta ante incidentes en tiempo real, garantizando una visibilidad 360° sin interrupciones.
            </p>
          </div>
        </div>

        <!-- Dashboard GIF -->
        <div class="flex justify-center lg:justify-end">
          <div class="rounded-2xl overflow-hidden shadow-xl max-w-2xl">
            <img 
              src="https://blogdatlas.wordpress.com/wp-content/uploads/2021/04/datlas_seguridad_plumpwidejackal-size_restricted.gif"
              alt="Dashboard de videovigilancia interactivo"
              class="w-full h-auto"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Casos reales de implementación -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <h2 class="text-center mb-8 text-gray-900">Casos reales de implementación</h2>
      <p class="text-center text-gray-600 mb-16 text-base leading-relaxed">
        <span class="hidden md:inline">Pasa el cursor sobre las tarjetas para ver más detalles</span>
        <span class="md:hidden">Toca las tarjetas para ver más detalles</span>
      </p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto mb-16">
        <!-- Terminal portuaria -->
        <div class="flip-card">
          <div class="flip-card-inner">
            <!-- Frente -->
            <div class="flip-card-front">
              <div class="h-full rounded-2xl relative overflow-hidden shadow-lg">
                <Image src={casoManzanillo} alt="Terminal portuaria Manzanillo" class="w-full h-full object-cover" loading="lazy"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 text-center">
                  <h3 class="text-white text-lg md:text-xl font-bold mb-2">Terminal portuaria en Manzanillo</h3>
                  <div class="mt-4 text-white/90 text-sm">
                    <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
            <!-- Reverso -->
            <div class="flip-card-back">
              <div class="h-full bg-white rounded-2xl p-5 md:p-6 flex flex-col justify-between shadow-xl border-2 border-blue-600">
                <div>
                  <h3 class="text-blue-700 text-base md:text-lg font-bold mb-3">Terminal Portuaria - Manzanillo</h3>
                  <div class="space-y-2 md:space-y-3 text-xs md:text-sm text-gray-700">
                    <div>
                      <p class="font-semibold text-gray-900">Alcance:</p>
                      <p>Sistema de videovigilancia perimetral con cámaras analíticas y expansión por fibra óptica para proteger dos almacenes.</p>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-900">Tecnología:</p>
                      <p>Genetec Security Center, cámaras Hanwha Vision.</p>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-900">Resultado:</p>
                      <p>Cumplimiento CTPAT y reducción 40% en respuesta.</p>
                    </div>
                  </div>
                </div>
                <div class="text-center mt-3">
                  <span class="text-xs text-gray-500">
                    <span class="hidden md:inline">Mueve el cursor fuera</span>
                    <span class="md:hidden">Toca nuevamente</span>
                    para regresar
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Hotel -->
        <div class="flip-card">
          <div class="flip-card-inner">
            <!-- Frente -->
            <div class="flip-card-front">
              <div class="h-full rounded-2xl relative overflow-hidden shadow-lg">
                <Image src={casoHotel} alt="Hotel Guadalajara" class="w-full h-full object-cover" loading="lazy"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 text-center">
                  <h3 class="text-white text-lg md:text-xl font-bold mb-2">Hotel en Guadalajara, Jalisco</h3>
                  <div class="mt-4 text-white/90 text-sm">
                    <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
            <!-- Reverso -->
            <div class="flip-card-back">
              <div class="h-full bg-white rounded-2xl p-5 md:p-6 flex flex-col justify-between shadow-xl border-2 border-amber-600">
                <div>
                  <h3 class="text-amber-700 text-base md:text-lg font-bold mb-3">Hotel Boutique - Guadalajara</h3>
                  <div class="space-y-2 md:space-y-3 text-xs md:text-sm text-gray-700">
                    <div>
                      <p class="font-semibold text-gray-900">Alcance:</p>
                      <p>Más de 100 cámaras IP con grabación centralizada, video wall para monitoreo y acceso remoto seguro.</p>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-900">Tecnología:</p>
                      <p>Genetec Security Center, cámaras Hanwha Vision.</p>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-900">Resultado:</p>
                      <p>Protección del huésped y cumplimiento LFPDPPP.</p>
                    </div>
                  </div>
                </div>
                <div class="text-center mt-3">
                  <span class="text-xs text-gray-500">
                    <span class="hidden md:inline">Mueve el cursor fuera</span>
                    <span class="md:hidden">Toca nuevamente</span>
                    para regresar
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Recinto fiscal -->
        <div class="flip-card">
          <div class="flip-card-inner">
            <!-- Frente -->
            <div class="flip-card-front">
              <div class="h-full rounded-2xl relative overflow-hidden shadow-lg">
                <Image src={casoAifa} alt="Recinto fiscal AIFA" class="w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 text-center">
                  <h3 class="text-white text-lg md:text-xl font-bold mb-2">Recinto fiscal dentro del AIFA</h3>
                  <div class="mt-4 text-white/90 text-sm">
                    <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
            <!-- Reverso -->
            <div class="flip-card-back">
              <div class="h-full bg-white rounded-2xl p-5 md:p-6 flex flex-col justify-between shadow-xl border-2 border-slate-700">
                <div>
                  <h3 class="text-slate-800 text-base md:text-lg font-bold mb-3">Recinto Fiscal AIFA</h3>
                  <div class="space-y-2 md:space-y-3 text-xs md:text-sm text-gray-700">
                    <div>
                      <p class="font-semibold text-gray-900">Alcance:</p>
                      <p>Sistema de más de 100 cámaras NDAA para cumplimiento de CTPAT y alta disponibilidad.</p>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-900">Tecnología:</p>
                      <p>Cámaras térmicas FLIR, analíticos Vaelsys, integración acceso.</p>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-900">Resultado:</p>
                      <p>Cumplimiento normativo y certificación nacional.</p>
                    </div>
                  </div>
                </div>
                <div class="text-center mt-3">
                  <span class="text-xs text-gray-500">
                    <span class="hidden md:inline">Mueve el cursor fuera</span>
                    <span class="md:hidden">Toca nuevamente</span>
                    para regresar
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Planta de cemento -->
        <div class="flip-card">
          <div class="flip-card-inner">
            <!-- Frente -->
            <div class="flip-card-front">
              <div class="h-full rounded-2xl relative overflow-hidden shadow-lg">
                <Image src={casoPlanta} alt="Planta de cemento Tecomán" class="w-full h-full object-cover" loading="lazy"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 text-center">
                  <h3 class="text-white text-lg md:text-xl font-bold mb-2">Planta de cemento en Tecomán</h3>
                  <div class="mt-4 text-white/90 text-sm">
                    <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
