  <!-- Formulario de Contacto -->
  <section id="contacto" class="section-padding bg-white">
    <div class="container-custom px-6">
      <div class="max-w-2xl mx-auto">
        <div class="bg-gray-50 rounded-2xl p-8 md:p-12 shadow-lg">
          <h2 class="text-3xl font-bold text-gray-900 mb-4 text-center">
            Platiquemos de tu proyecto
          </h2>
          <p class="text-gray-600 text-center mb-8">Elige la forma que te sea más cómoda:</p>

          <!-- Botón WhatsApp -->
          <div class="mb-8 flex justify-center">
            <a href="https://wa.me/523121626888" target="_blank" class="inline-flex items-center gap-2 bg-green-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-green-700 transition-colors shadow-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          </div>

          <div class="text-center text-gray-500 mb-6">o déjanos tus datos</div>

          <!-- Formulario -->
          <form action="/api/contacto-software" method="POST" class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="telefono" class="block text-sm font-medium text-gray-700 mb-2">
                  Número de teléfono <span class="text-red-600">*</span>
                </label>
                <input 
                  type="tel" 
                  id="telefono"
                  name="telefono"
                  required
                  placeholder="+52 (55) 1234-5678"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-transparent"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  Correo electrónico <span class="text-red-600">*</span>
                </label>
                <input 
                  type="email" 
                  id="email"
                  name="email"
                  required
                  placeholder="maria@acme.com"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-transparent"
                />
              </div>
            </div>

            <div>
              <label for="empresa" class="block text-sm font-medium text-gray-700 mb-2">
                Empresa <span class="text-red-600">*</span>
              </label>
              <input 
                type="text" 
                id="empresa"
                name="empresa"
                required
                placeholder="Acme Corp"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-transparent"
              />
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-2">
                Mensaje <span class="text-gray-500">(opcional)</span>
              </label>
              <textarea 
                id="mensaje"
                name="mensaje"
                rows="4"
                placeholder="Cuéntanos en qué podemos ayudarte..."
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-transparent resize-none"
              ></textarea>
            </div>

            <div class="flex items-start gap-2">
              <input 
                type="checkbox" 
                id="autorizacion"
                name="autorizacion"
                required
                class="mt-1"
              />
              <label for="autorizacion" class="text-sm text-gray-600">
                Autorizo ser contactado/a por este medio para recibir información sobre los servicios. <span class="text-red-600">*</span>
              </label>
            </div>

            <button 
              type="submit"
              class="w-full bg-gray-900 text-white px-8 py-4 rounded-lg font-semibold hover:bg-gray-800 transition-colors"
            >
              Recibir cotización
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
