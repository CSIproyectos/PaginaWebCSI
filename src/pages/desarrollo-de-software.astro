---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../img/soluciones/desarrolloDeSoftware/programacion.jpg';
---

<Layout 
  title="Desarrollo de Software - CSI"
  description="Soluciones digitales a medida: aplicaciones web, móviles, ERP/CRM, dashboards y automatización de procesos."
>
  <!-- Hero Section -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={heroImage}
        alt="Desarrollo de Software"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/70"></div>
    </div>
    
    <div class="container-custom px-6 relative z-10 text-center text-white">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Desarrollo de Software
      </h1>
      <p class="text-xl md:text-2xl text-gray-200 max-w-3xl mx-auto mb-8">
        Software a medida para automatizar tu operación y eliminar trabajo manual
      </p>
      
      <div class="flex justify-center">
        <a href="#contacto" class="inline-flex items-center justify-center bg-white text-gray-900 px-8 py-4 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
          Dejar mis datos
        </a>
      </div>
    </div>
  </section>

  <!-- Beneficios Clave -->
  <section class="section-padding bg-white">
    <div class="container-custom px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <!-- MVP rápido -->
        <div class="bg-gray-50 rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-gray-900 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">MVP en 2–4 sem</h3>
          <p class="text-sm text-gray-600">Resultados rápidos y tangibles</p>
        </div>

        <!-- Sprints semanales -->
        <div class="bg-gray-50 rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-gray-900 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Sprints semanales</h3>
          <p class="text-sm text-gray-600">Avance visible cada semana</p>
        </div>

        <!-- México & LATAM -->
        <div class="bg-gray-50 rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-gray-900 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">México & LATAM</h3>
          <p class="text-sm text-gray-600">Presencia regional establecida</p>
        </div>

        <!-- Código tuyo -->
        <div class="bg-gray-50 rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-gray-900 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Código tuyo</h3>
          <p class="text-sm text-gray-600">Repo + docs + handoff completo</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Descripción Detallada -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Construimos sistemas internos, integraciones y dashboards
        </h2>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          Para empresas en México y LATAM que necesitan automatizar procesos manuales, conectar sistemas existentes o crear herramientas específicas para su operación.
        </p>
        
        <div class="grid md:grid-cols-3 gap-6 text-sm text-gray-600 mb-8">
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Sprints semanales + demo</span>
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Repo + documentación + handoff</span>
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Seguridad base incluida</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proyectos Típicos -->
  <section class="section-padding bg-white">
    <div class="container-custom px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Proyectos típicos
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto mb-8">
          Cada proyecto es diferente. Diseñamos y construimos software adaptado a tu operación — cero productos genéricos.
        </p>
        
        <div class="flex justify-center">
          <img 
            src="https://media3.giphy.com/media/v1.Y2lkPTc5MGI3NjExb2M3OHhuNG83bHd3YTBrczQ5MHlpNHRvbzk0ZjEydXhhZ2YydnQxMCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/E470LZUmy2Jiw/giphy.gif"
            alt="Software Development Animation"
            class="rounded-xl shadow-lg max-w-md w-full"
          />
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Automatización de procesos -->
        <div class="bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-md">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Automatización de procesos</h3>
          <p class="text-gray-600 text-center">
            Aprovisionamientos, reportes, conciliaciones, flujos internos, portales, bitácoras. Eliminamos el trabajo manual repetitivo de tu operación.
          </p>
        </div>

        <!-- Integraciones y APIs -->
        <div class="bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-md">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Integraciones y APIs</h3>
          <p class="text-gray-600 text-center">
            ERP/CRM, facturación, pagos, hojas de cálculo, proveedores, sincronización de datos. Conectamos tus sistemas para que hablen entre sí.
          </p>
        </div>

        <!-- Dashboards y control operativo -->
        <div class="bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-md">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Dashboards y control operativo</h3>
          <p class="text-gray-600 text-center">
            KPIs, alertas, trazabilidad, permisos por rol, auditoría de cambios. Visibilidad total de tu operación en tiempo real.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Entrega sin sorpresas -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Entrega sin sorpresas
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Un proceso claro que reduce riesgo y te da visibilidad desde el día uno.
        </p>
      </div>

      <!-- Proceso -->
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto mb-16">
        <!-- Sprint 0 -->
        <div class="text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-md">
            <span class="text-3xl font-bold text-gray-900">0</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Sprint 0 <span class="text-gray-600 font-normal">(2–5 días)</span></h3>
          <p class="text-gray-600">
            Entendemos el proceso, definimos alcance, backlog y estimación. Sin compromiso hasta que el plan te convenza.
          </p>
        </div>

        <!-- MVP -->
        <div class="text-center">
          <div class="w-20 h-20 bg-gray-900 rounded-full flex items-center justify-center mx-auto mb-6 shadow-md">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">MVP <span class="text-gray-600 font-normal">(2–4 semanas)</span></h3>
          <p class="text-gray-600">
            Versión funcional en producción + pruebas básicas. Ya puedes usar el sistema y dar feedback real.
          </p>
        </div>

        <!-- Iteraciones semanales -->
        <div class="text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-md">
            <svg class="w-10 h-10 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Iteraciones semanales</h3>
          <p class="text-gray-600">
            Mejoras con feedback real. Cada semana ves avance concreto, con demo y revisión de prioridades.
          </p>
        </div>
      </div>

      <!-- Lo que recibes al final -->
      <div class="bg-white rounded-2xl p-8 md:p-12 shadow-lg max-w-5xl mx-auto">
        <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">Lo que recibes al final</h3>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Sistema funcionando -->
          <div class="text-center">
            <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 mb-2">Tu sistema funcionando</h4>
            <p class="text-sm text-gray-600">Listo para usar desde día uno</p>
          </div>

          <!-- Código es tuyo -->
          <div class="text-center">
            <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 mb-2">El código es tuyo</h4>
            <p class="text-sm text-gray-600">Acceso completo al proyecto, sin candados</p>
          </div>

          <!-- Manuales y capacitación -->
          <div class="text-center">
            <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 mb-2">Manuales y capacitación</h4>
            <p class="text-sm text-gray-600">Para que tu equipo lo opere sin depender de nosotros</p>
          </div>

          <!-- Publicado y vigilado -->
          <div class="text-center">
            <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 mb-2">Publicado y vigilado</h4>
            <p class="text-sm text-gray-600">Lo dejamos en línea con alertas si algo falla</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ejemplos de proyectos -->
  <section class="section-padding bg-white">
    <div class="container-custom px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Ejemplos de proyectos que hemos construido
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Casos reales donde resolvimos problemas de operación con software a medida.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Gestión de proyectos -->
        <div class="bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-6 shadow-md">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Gestión Integral de Proyectos y Equipos</h3>
          <p class="text-gray-600 mb-4">
            Sistema completo para planificación, seguimiento y control de proyectos con asignación de recursos, cronogramas y reportes de avance en tiempo real.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Planificación</span>
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Seguimiento</span>
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Reportes</span>
          </div>
        </div>

        <!-- Control de gastos -->
        <div class="bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-6 shadow-md">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Sistema de Control de Gastos y Viáticos Corporativos</h3>
          <p class="text-gray-600 mb-4">
            Plataforma para registro, aprobación y reembolso de gastos corporativos con políticas automáticas y conciliación contable integrada.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Registro de gastos</span>
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Aprobaciones</span>
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Conciliación</span>
          </div>
        </div>

        <!-- Plataformas a medida -->
        <div class="bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-6 shadow-md">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Desarrollo de Plataformas Web y Aplicaciones a Medida</h3>
          <p class="text-gray-600 mb-4">
            Soluciones personalizadas desde cero: portales web, aplicaciones móviles, sistemas internos y plataformas especializadas adaptadas a tu negocio.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Web apps</span>
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Mobile apps</span>
            <span class="px-3 py-1 bg-white text-gray-700 rounded-full text-xs font-medium">Sistemas internos</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tecnologías -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Tecnologías
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
